# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------
# Frontend (Vite). These are shipped to the browser — only publishable values.
# ---------------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Lightweight shared access token sent with every edge-function call so the raw
# function URL alone isn't enough to spend the Anthropic key. This is a
# bar-raiser, not real auth (it ships in the client bundle). It MUST equal the
# SCAN_ACCESS_TOKEN secret configured on the Supabase edge functions.
VITE_SCAN_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# NOT frontend vars. Configure these as Supabase Edge Function secrets
# (Dashboard > Project Settings > Edge Functions > Secrets), never here:
#
#   ANTHROPIC_API_KEY          Anthropic API key spent by analyze-code
#   SCAN_ACCESS_TOKEN          must equal VITE_SCAN_ACCESS_TOKEN above
#   ANALYSIS_MODEL             pinned Claude model id (default claude-sonnet-4-5-20250929)
#   RATE_LIMIT_MAX             scans per window per IP (default 5)
#   RATE_LIMIT_WINDOW_SECONDS  rate-limit window length (default 3600 = 1h)
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
# Supabase runtime and are used by the rate limiter to reach the counters table.
# ---------------------------------------------------------------------------
